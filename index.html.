/* ---- Acceso secreto: 3 clics en el logo "Sweet Joy" ---- */
let _logoClickCount = 0, _logoClickTimer = null;
function handleLogoClick(e) {
  e.preventDefault();
  _logoClickCount++;
  clearTimeout(_logoClickTimer);
  _logoClickTimer = setTimeout(() => { _logoClickCount = 0; }, 1200);
  if (_logoClickCount >= 3) {
    _logoClickCount = 0;
    openErpLogin();
  }
}

function openErpLogin() {
  document.getElementById('erpLoginOverlay').style.display = 'flex';
  document.getElementById('erpLoginError').style.display = 'none';
  document.getElementById('erpLoginUser').value = '';
  document.getElementById('erpLoginPass').value = '';
  document.getElementById('erpLoginUser').focus();
}
document.getElementById('erpLoginOverlay').addEventListener('click', function(e){
  if (e.target === this) closeErpLogin();
});
function closeErpLogin() {
  document.getElementById('erpLoginOverlay').style.display = 'none';
}

function erpIntentarLogin() {
  const usuario = document.getElementById('erpLoginUser').value.trim();
  const password = document.getElementById('erpLoginPass').value;
  const db = getSharedDB();
  const u = (db.usuarios||[]).find(x => x.usuario === usuario && x.password === password);
  const errEl = document.getElementById('erpLoginError');
  const fallbackEl = document.getElementById('erpLoginFallback');
  errEl.style.display = 'none';
  fallbackEl.style.display = 'none';
  if (!u) { errEl.textContent = '⚠ Usuario o contraseña incorrectos.'; errEl.style.display = 'block'; return; }
  if (!u.activo) { errEl.textContent = '⚠ Este usuario está inactivo.'; errEl.style.display = 'block'; return; }
  // Comparte el token de sesión con la pestaña del ERP (mismo origen)
  sessionStorage.setItem('sweetjoy_auth', JSON.stringify({ id: u.id, usuario: u.usuario }));

  // Construir la URL del ERP relativa a la carpeta actual (funciona en file:// y en servidor web)
  const erpUrl = new URL(encodeURI(ERP_FILE), window.location.href).href;
  document.getElementById('erpFallbackLink').href = erpUrl;

  const newTab = window.open(erpUrl, '_blank');
  if (!newTab || newTab.closed || typeof newTab.closed === 'undefined') {
    // El navegador bloqueó el popup o no encontró el archivo: mostramos enlace manual
    fallbackEl.style.display = 'block';
  } else {
    closeErpLogin();
  }
}

const WHATSAPP_NUMBER = '51907034487';
let cart = [];

function getProductImage(id) {
  const img = document.getElementById('img-' + id);
  return img ? img.src : '';
}

function formatMoney(n) {
  return 'S/ ' + n.toFixed(2);
}

function showToast(text) {
  const toast = document.getElementById('toastMsg');
  toast.textContent = text;
  toast.classList.add('show');
  clearTimeout(window._toastTimeout);
  window._toastTimeout = setTimeout(() => toast.classList.remove('show'), 2200);
}

function addToCart(id, name, price) {
  const existing = cart.find(i => i.id === id);
  if (existing) {
    existing.qty += 1;
  } else {
    cart.push({ id, name, price: parseFloat(price), qty: 1, img: getProductImage(id) });
  }
  renderCart();
  showToast('🍓 "' + name + '" se agregó al carrito');
  openCart();
}

function changeQty(id, delta) {
  const item = cart.find(i => i.id === id);
  if (!item) return;
  item.qty += delta;
  if (item.qty <= 0) {
    cart = cart.filter(i => i.id !== id);
  }
  renderCart();
}

function removeFromCart(id) {
  cart = cart.filter(i => i.id !== id);
  renderCart();
}

function cartTotal() {
  return cart.reduce((sum, i) => sum + i.price * i.qty, 0);
}

function cartCount() {
  return cart.reduce((sum, i) => sum + i.qty, 0);
}

function renderCart() {
  const list = document.getElementById('cartItemsList');
  const footer = document.getElementById('cartFooter');
  const badge = document.getElementById('cartCountBadge');
  const count = cartCount();

  badge.textContent = count;
  badge.classList.toggle('hidden-badge', count === 0);

  if (cart.length === 0) {
    list.innerHTML = '<div class="cart-empty"><span>🍰</span>Tu carrito está vacío.<br>¡Elige algo delicioso de la carta!</div>';
    footer.style.display = 'none';
    return;
  }

  footer.style.display = 'block';
  list.innerHTML = cart.map(item => {
    const subtotal = item.price * item.qty;
    return `
      <div class="cart-item">
        <img src="${item.img}" alt="${item.name}">
        <div class="cart-item-info">
          <h4>${item.name}</h4>
          <div class="ci-price">${formatMoney(item.price)} c/u</div>
          <div class="cart-item-controls">
            <button type="button" class="qty-btn" onclick="changeQty('${item.id}', -1)" aria-label="Disminuir">−</button>
            <span class="qty-val">${item.qty}</span>
            <button type="button" class="qty-btn" onclick="changeQty('${item.id}', 1)" aria-label="Aumentar">+</button>
          </div>
        </div>
        <div class="cart-item-right">
          <div class="cart-item-subtotal">${formatMoney(subtotal)}</div>
          <button type="button" class="cart-remove-btn" onclick="removeFromCart('${item.id}')">Eliminar</button>
        </div>
      </div>
    `;
  }).join('');

  document.getElementById('cartTotalAmount').textContent = formatMoney(cartTotal());
}

function openCart() {
  document.getElementById('cartOverlay').classList.add('open');
  document.getElementById('cartDrawer').classList.add('open');
}

function closeCart() {
  document.getElementById('cartOverlay').classList.remove('open');
  document.getElementById('cartDrawer').classList.remove('open');
}

function finalizarPedido() {
  if (cart.length === 0) {
    showToast('Tu carrito está vacío');
    return;
  }
  const nameInput = document.getElementById('checkoutName');
  const phoneInput = document.getElementById('checkoutPhone');
  const addressInput = document.getElementById('checkoutAddress');
  const clientName = nameInput.value.trim();
  const clientPhone = phoneInput.value.trim();
  const clientAddress = addressInput.value.trim();

  if (!clientName || !clientPhone || !clientAddress) {
    showToast('Por favor completa nombre, teléfono y dirección');
    if (!clientName) nameInput.focus();
    else if (!clientPhone) phoneInput.focus();
    else addressInput.focus();
    return;
  }

  const now = new Date();
  const fecha = now.toLocaleDateString('es-PE', { day: '2-digit', month: '2-digit', year: 'numeric' });
  const hora = now.toLocaleTimeString('es-PE', { hour: '2-digit', minute: '2-digit' });

  // Registrar el pedido en la base de datos compartida con el ERP
  const db = getSharedDB();
  if (!db.pedidosWeb) db.pedidosWeb = [];
  if (!db.nextId) db.nextId = {};
  if (!db.nextId.web) db.nextId.web = 1;

  const numero = 'WEB-' + String(db.nextId.web).padStart(4, '0');
  const pedido = {
    id: 'pw_' + Date.now(),
    numero,
    fecha, hora,
    cliente: clientName,
    telefono: clientPhone,
    direccion: clientAddress,
    productos: cart.map(i => ({ nombre: i.name, cantidad: i.qty, precio: i.price })),
    total: cartTotal(),
    estado: 'Pendiente',
    origen: 'Landing Page'
  };
  db.pedidosWeb.push(pedido);
  db.nextId.web += 1;
  saveSharedDB(db);

  cart = [];
  renderCart();
  closeCart();
  showToast('✅ ¡Pedido ' + numero + ' enviado correctamente! Te contactaremos pronto.');
}


